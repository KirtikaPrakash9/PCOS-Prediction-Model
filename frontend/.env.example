# URL of the deployed Flask backend (no trailing slash)
# For local development this defaults to http://localhost:5000
NEXT_PUBLIC_API_URL=https://your-backend.railway.app

# ---- Backend environment variables (set on Railway / Render) ----
# Comma-separated list of allowed frontend origins.
# Defaults to localhost:3000 and https://pcos-prediction-model.vercel.app.
# Override this env var to restrict or expand CORS in production.
# CORS_ORIGINS=https://pcos-prediction-model.vercel.app
